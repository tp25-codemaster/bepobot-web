{
  "functions": {
    "api/router.ts": {
      "includeFiles": "api/_handlers/**"
    }
  },
  "crons": [
    {
      "path": "/api/bot-gmail-poll",
      "schedule": "*/2 * * * *"
    }
  ],
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/router" },
    { "source": "/app", "destination": "/index.html" },
    { "source": "/app/:path*", "destination": "/index.html" },
    { "source": "/evisitor", "destination": "/index.html" },
    { "source": "/evisitor/:path*", "destination": "/index.html" },
    { "source": "/checkin/:token", "destination": "/index.html" }
  ]
}
