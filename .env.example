# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Google OAuth (Gmail integration)
# Rotate immediately if ever exposed — never use hardcoded fallbacks
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Pub/Sub webhook protection — include in subscription URL: ?token=<this value>
PUBSUB_WEBHOOK_SECRET=your-random-32-char-secret

# Internal API secret — shared between gmail-refresh, send-email, and callers (n8n)
EMAIL_API_SECRET=your-random-secret

# Vercel cron protection (set automatically by Vercel, but required)
CRON_SECRET=your-cron-secret

# n8n Webhooks
VITE_N8N_WEBHOOK_URL=https://your-n8n.app.n8n.cloud/webhook
VITE_EVISITOR_WEBHOOK_URL=https://your-n8n.app.n8n.cloud/webhook/evisitor-checkin
